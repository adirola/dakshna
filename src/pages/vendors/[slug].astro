---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VendorCard from '../../components/VendorCard.astro';
import { CATEGORY_LABELS, PRICING_LABELS } from '../../lib/vendors';

export async function getStaticPaths() {
  const vendors = await getCollection('vendors');
  return vendors.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'vendors'>;
}

const { entry } = Astro.props;
const vendor = entry.data;

// Resolve related vendors by slug; skip any that no longer exist
const relatedVendors = vendor.related.length
  ? (await getCollection('vendors'))
      .filter((v) => vendor.related.includes(v.data.slug))
      .map((v) => v.data)
  : [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  {
    label: CATEGORY_LABELS[vendor.category] ?? vendor.category,
    href: `/category/${vendor.category}`,
  },
  { label: vendor.name },
];
---

<BaseLayout title={`${vendor.name} — Dakshna`} description={vendor.description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <Breadcrumbs items={breadcrumbs} />

    <!-- Vendor header -->
    <header class="mt-6">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <h1 class="font-display text-3xl font-bold text-neutral-900">{vendor.name}</h1>
        <div class="flex gap-2 flex-wrap">
          {vendor.featured && (
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-accent-400 text-white">
              <svg class="w-3 h-3" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              Featured
            </span>
          )}
          {vendor.verified && (
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-800">
              <svg class="w-3.5 h-3.5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Verified
            </span>
          )}
        </div>
      </div>

      <!-- Meta row -->
      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-neutral-500">
        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-600">
          {CATEGORY_LABELS[vendor.category] ?? vendor.category}
        </span>
        <span aria-hidden="true">·</span>
        <span class="capitalize">{vendor.city}</span>
        {vendor.region && (
          <>
            <span aria-hidden="true">·</span>
            <span class="capitalize">{vendor.region.replace(/-/g, ' ')}</span>
          </>
        )}
        <span aria-hidden="true">·</span>
        <span class="font-medium text-neutral-700">{PRICING_LABELS[vendor.pricingRange]}</span>
      </div>
    </header>

    <!-- Description -->
    <p class="mt-5 text-base text-neutral-700 leading-relaxed max-w-2xl">{vendor.description}</p>

    <!-- External website CTA -->
    {vendor.url && (
      <a
        href={vendor.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 transition-colors"
      >
        Visit Website
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
        </svg>
      </a>
    )}

    <!-- Tags -->
    {vendor.tags.length > 0 && (
      <div class="mt-10">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-3">Tags</h2>
        <div class="flex flex-wrap gap-2">
          {vendor.tags.map((tag) => (
            <span class="rounded-full border border-neutral-200 bg-neutral-50 px-3 py-1 text-xs text-neutral-600">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Related vendors -->
    {relatedVendors.length > 0 && (
      <section class="mt-14">
        <h2 class="font-display text-xl font-semibold text-neutral-900 mb-6">Related Vendors</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {relatedVendors.map((relatedVendor) => (
            <VendorCard vendor={relatedVendor} />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminVendorForm from '../../components/AdminVendorForm';

// Admin-only page — assumes trusted local dev or Cloudflare Access protection.
// No auth is enforced here; protect at the infra level if needed.
---

<BaseLayout
  title="Add Vendor"
  description="Internal tool for adding vendor listings to Dakshna."
  noIndex={true}
>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-2">
        <span class="inline-block px-2 py-0.5 rounded bg-amber-100 text-amber-700 text-xs font-semibold uppercase tracking-wide">
          Admin
        </span>
        <span class="text-neutral-400 text-sm">Local dev tool</span>
      </div>
      <h1 class="text-2xl font-display font-semibold text-neutral-900">Add Vendor</h1>
      <p class="text-neutral-600 text-sm mt-1">
        Fill in the form to generate a vendor JSON file. Download it, place it in
        <code class="bg-neutral-100 px-1 rounded text-xs">src/content/vendors/</code>, commit, and push.
      </p>
    </div>

    <AdminVendorForm client:load />
  </div>
</BaseLayout>

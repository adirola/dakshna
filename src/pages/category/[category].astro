---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VendorCard from '../../components/VendorCard.astro';
import { CATEGORIES } from '../../data/categories';

export async function getStaticPaths() {
  const categoryKeys = Object.keys(CATEGORIES) as Array<keyof typeof CATEGORIES>;
  const allVendors = await getCollection('vendors');

  return categoryKeys.map((category) => {
    const vendors = allVendors
      .filter((entry) => entry.data.category === category)
      .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

    return {
      params: { category },
      props: { vendors },
    };
  });
}

interface Props {
  vendors: CollectionEntry<'vendors'>[];
}

const { category } = Astro.params;
const { vendors } = Astro.props;

const meta = CATEGORIES[category] ?? {
  label: category,
  description: `Browse ${category} vendors on Dakshna.`,
};

const cities = [...new Set(vendors.map((v) => v.data.city))].sort();

const PRICING_ORDER = ['budget', 'mid', 'premium', 'luxury'];
const pricingRanges = [...new Set(vendors.map((v) => v.data.pricing_range))].sort(
  (a, b) => PRICING_ORDER.indexOf(a) - PRICING_ORDER.indexOf(b)
);

const PRICING_LABELS: Record<string, string> = {
  budget: 'Budget',
  mid: 'Mid-Range',
  premium: 'Premium',
  luxury: 'Luxury',
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: meta.label, href: `/category/${category}` },
];

const PAGE_SIZE = 12;
---

<BaseLayout title={meta.label} description={meta.description}>
  <div class="container mx-auto px-4 py-8 max-w-7xl">

    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6 mb-8">
      <h1 class="text-3xl font-bold text-gray-900">{meta.label}</h1>
      <p class="mt-2 text-lg text-gray-600 max-w-3xl">{meta.description}</p>
    </header>

    {vendors.length === 0 ? (
      <div class="rounded-xl border border-dashed border-gray-300 bg-gray-50 py-20 text-center">
        <p class="text-lg font-medium text-gray-500">No listings yet in this category.</p>
        <p class="mt-2 text-sm text-gray-400">
          Check back soon, or{' '}
          <a href="#" class="text-rose-600 underline hover:text-rose-700">
            submit a listing
          </a>.
        </p>
      </div>
    ) : (
      <div class="lg:flex lg:gap-8">

        {(cities.length > 1 || pricingRanges.length > 1) && (
          <aside class="mb-6 lg:mb-0 lg:w-56 lg:shrink-0">
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm sticky top-6">
              <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Filter</h2>

              {cities.length > 1 && (
                <div class="mb-5">
                  <label for="filter-city" class="block text-xs font-medium text-gray-500 mb-1">City</label>
                  <select
                    id="filter-city"
                    class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700 focus:border-rose-400 focus:outline-none focus:ring-1 focus:ring-rose-400"
                  >
                    <option value="">All cities</option>
                    {cities.map((city) => (
                      <option value={city.toLowerCase()}>{city}</option>
                    ))}
                  </select>
                </div>
              )}

              {pricingRanges.length > 1 && (
                <div>
                  <label for="filter-pricing" class="block text-xs font-medium text-gray-500 mb-1">Pricing</label>
                  <select
                    id="filter-pricing"
                    class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700 focus:border-rose-400 focus:outline-none focus:ring-1 focus:ring-rose-400"
                  >
                    <option value="">All price ranges</option>
                    {pricingRanges.map((range) => (
                      <option value={range}>{PRICING_LABELS[range] ?? range}</option>
                    ))}
                  </select>
                </div>
              )}

              <button
                id="filter-reset"
                class="mt-4 w-full rounded-lg border border-gray-200 px-3 py-2 text-xs font-medium text-gray-500 hover:bg-gray-50 transition-colors"
              >
                Reset filters
              </button>
            </div>
          </aside>
        )}

        <div class="flex-1 min-w-0">

          <p id="result-count" class="text-sm text-gray-500 mb-4">
            Showing <span id="visible-count">{vendors.length}</span> of {vendors.length} listings
          </p>

          <div id="vendor-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {vendors.map((entry) => (
              <div
                class="vendor-card-wrapper"
                data-city={entry.data.city.toLowerCase()}
                data-pricing={entry.data.pricing_range}
              >
                <VendorCard vendor={entry.data} />
              </div>
            ))}
          </div>

          <div id="no-results" class="hidden py-16 text-center">
            <p class="text-gray-500">No vendors match your current filters.</p>
            <button
              id="no-results-reset"
              class="mt-3 text-sm text-rose-600 underline hover:text-rose-700"
            >
              Clear filters
            </button>
          </div>

          {vendors.length > PAGE_SIZE && (
            <nav id="pagination" class="mt-10 flex items-center justify-center gap-2" aria-label="Pagination">
              <button
                id="page-prev"
                class="rounded-lg border border-gray-200 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
                disabled
              >
                ← Previous
              </button>
              <span id="page-indicator" class="text-sm text-gray-600 px-2">
                Page <span id="current-page">1</span> of <span id="total-pages">1</span>
              </span>
              <button
                id="page-next"
                class="rounded-lg border border-gray-200 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
              >
                Next →
              </button>
            </nav>
          )}

        </div>
      </div>
    )}
  </div>
</BaseLayout>

<script define:vars={{ PAGE_SIZE }}>
  (() => {
    const wrappers = Array.from(document.querySelectorAll('.vendor-card-wrapper'));
    if (wrappers.length === 0) return;

    const citySelect = document.getElementById('filter-city');
    const pricingSelect = document.getElementById('filter-pricing');
    const resetBtn = document.getElementById('filter-reset');
    const noResultsResetBtn = document.getElementById('no-results-reset');
    const resultCountEl = document.getElementById('visible-count');
    const noResults = document.getElementById('no-results');
    const pagination = document.getElementById('pagination');
    const prevBtn = document.getElementById('page-prev');
    const nextBtn = document.getElementById('page-next');
    const currentPageEl = document.getElementById('current-page');
    const totalPagesEl = document.getElementById('total-pages');

    let currentPage = 1;
    let filteredWrappers = wrappers.slice();

    function getFilteredWrappers() {
      const city = citySelect?.value ?? '';
      const pricing = pricingSelect?.value ?? '';
      return wrappers.filter((el) => {
        const matchCity = !city || el.dataset.city === city;
        const matchPricing = !pricing || el.dataset.pricing === pricing;
        return matchCity && matchPricing;
      });
    }

    function render() {
      filteredWrappers = getFilteredWrappers();
      const totalPages = Math.max(1, Math.ceil(filteredWrappers.length / PAGE_SIZE));
      currentPage = Math.min(currentPage, totalPages);

      const startIdx = (currentPage - 1) * PAGE_SIZE;
      const visibleSet = new Set(filteredWrappers.slice(startIdx, startIdx + PAGE_SIZE));

      wrappers.forEach((el) => {
        el.style.display = visibleSet.has(el) ? '' : 'none';
      });

      if (resultCountEl) resultCountEl.textContent = String(filteredWrappers.length);
      if (noResults) noResults.classList.toggle('hidden', filteredWrappers.length > 0);
      if (pagination) pagination.classList.toggle('hidden', totalPages <= 1);
      if (currentPageEl) currentPageEl.textContent = String(currentPage);
      if (totalPagesEl) totalPagesEl.textContent = String(totalPages);
      if (prevBtn) prevBtn.disabled = currentPage <= 1;
      if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    }

    function resetFilters() {
      if (citySelect) citySelect.value = '';
      if (pricingSelect) pricingSelect.value = '';
      currentPage = 1;
      render();
    }

    citySelect?.addEventListener('change', () => { currentPage = 1; render(); });
    pricingSelect?.addEventListener('change', () => { currentPage = 1; render(); });
    resetBtn?.addEventListener('click', resetFilters);
    noResultsResetBtn?.addEventListener('click', resetFilters);
    prevBtn?.addEventListener('click', () => { currentPage -= 1; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
    nextBtn?.addEventListener('click', () => { currentPage += 1; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); });

    render();
  })();
</script>

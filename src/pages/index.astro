---
import '../styles/global.css';
import { Button } from '@/components/ui/button';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dakshna — Indian Wedding Vendor Directory</title>
  </head>
  <body class="bg-background text-foreground font-sans">
    <main class="container mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold text-brand-900">Dakshna</h1>
      <p class="mt-4 text-lg text-muted-foreground">
        The AI-native Indian wedding vendor directory.
      </p>
      <div class="mt-8">
        <Button client:load>Browse Vendors</Button>
      </div>
    </main>
  </body>
</html>

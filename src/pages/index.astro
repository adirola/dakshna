---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedCarousel from '../components/FeaturedCarousel.astro';
import { getFeaturedVendors } from '../lib/vendors';

const allVendors = await getCollection('vendors');
const featuredVendors = getFeaturedVendors(allVendors, 8).map(v => v.data);

const CATEGORY_LABELS: Record<string, string> = {
  venue: 'Wedding Venues',
  photographer: 'Photographers',
  makeup: 'Makeup Artists',
  caterer: 'Caterers',
  decorator: 'Decorators',
  dj: 'DJs & Live Music',
  pandit: 'Pandits & Priests',
  planner: 'Wedding Planners',
};

const categories = [
  'venue', 'photographer', 'makeup', 'caterer',
  'decorator', 'dj', 'pandit', 'planner',
] as const;
---

<BaseLayout
  title="Dakshna — Indian Wedding Vendor Directory"
  description="Discover trusted venues, photographers, caterers, and more for your Indian wedding. Browse hundreds of curated listings across India."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="font-display text-4xl font-bold text-neutral-900 mb-2">
      Find Your Perfect Wedding Vendors
    </h1>
    <p class="text-lg text-neutral-600 mb-10 font-accent italic">
      The AI-native Indian wedding directory
    </p>

    <FeaturedCarousel vendors={featuredVendors} />

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Browse by Category</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {categories.map(cat => (
          <a
            href={`/category/${cat}`}
            class="rounded-xl border border-neutral-200 bg-white p-4 text-center shadow-sm hover:border-primary-300 hover:shadow-md transition-all"
          >
            <span class="text-sm font-medium text-neutral-700">{CATEGORY_LABELS[cat]}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

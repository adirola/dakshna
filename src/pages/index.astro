---

<BaseLayout title="Dakshna — Indian Wedding Vendor Directory">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="font-display text-4xl font-bold text-neutral-900 mb-2">
      Find Your Perfect Wedding Vendors
    </h1>
    <p class="text-lg text-neutral-600 mb-10 font-accent italic">
      The AI-native Indian wedding directory
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {mockVendors.map(vendor => (
        <VendorCard vendor={vendor} />
      ))}
    </div>

    <Pagination currentPage={1} totalPages={5} baseUrl="/vendors" />
  </div>
</BaseLayout>

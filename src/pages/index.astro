---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import VendorCard from '../components/VendorCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CityCard from '../components/CityCard.astro';
import { CATEGORIES, FEATURED_CITIES } from '../lib/constants';

const allVendors = await getCollection('vendors');

const featuredVendors = allVendors
  .filter(v => v.data.featured)
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, 8);

const recentVendors = allVendors
  .filter(v => !v.data.featured)
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, 6);

const cityCounts = allVendors.reduce<Record<string, number>>((acc, v) => {
  const city = v.data.city.toLowerCase();
  acc[city] = (acc[city] ?? 0) + 1;
  return acc;
}, {});

const populatedCities = FEATURED_CITIES.filter(c => (cityCounts[c.slug] ?? 0) > 0);
---

<BaseLayout
  title="Dakshna — Indian Wedding Vendor Directory"
  description="Find the best wedding venues, photographers, caterers, makeup artists, and more for Indian weddings across India and the diaspora."
  ogType="website"
  canonicalUrl="https://dakshna.com/"
>
  <!-- Section 1: Hero -->
  <section class="relative bg-gradient-to-br from-primary-50 via-surface to-accent-50 py-20 sm:py-28 overflow-hidden">
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-accent italic text-primary-600 text-lg mb-3">India's AI-native wedding directory</p>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 leading-tight">
        Find the perfect vendors<br />
        <span class="text-primary-600">for your celebration</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-neutral-600 max-w-2xl mx-auto">
        Venues, photographers, caterers, makeup artists, and more — curated for Indian weddings across India and the diaspora.
      </p>

      <!-- Search stub (wired up in a later task) -->
      <div class="mt-8 max-w-xl mx-auto">
        <button
          id="hero-search-trigger"
          type="button"
          class="w-full flex items-center gap-3 px-5 py-3.5 bg-white border border-neutral-200 rounded-full shadow-card text-neutral-500 hover:border-primary-300 hover:shadow-card-hover transition-all text-left"
          aria-label="Search for vendors"
        >
          <svg class="w-5 h-5 flex-shrink-0" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="flex-1">Search venues, photographers, cities…</span>
          <kbd class="text-xs bg-neutral-100 border border-neutral-200 rounded px-1.5 py-0.5 font-sans">⌘K</kbd>
        </button>
      </div>

      <!-- Quick CTA chips -->
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <a
          href="/vendors?city=bangalore"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/80 border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50 transition-colors"
        >
          Bangalore vendors
        </a>
        <a
          href="/category/venue"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/80 border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50 transition-colors"
        >
          Wedding venues
        </a>
        <a
          href="/category/photographer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/80 border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50 transition-colors"
        >
          Photographers
        </a>
      </div>
    </div>
  </section>

  <!-- Section 2: Featured Vendors -->
  {featuredVendors.length > 0 && (
    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-display text-2xl font-semibold text-neutral-900">Featured Vendors</h2>
          <a href="/vendors?featured=true" class="text-sm text-primary-600 hover:underline">View all →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {featuredVendors.map(vendor => (
            <VendorCard vendor={vendor.data} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 3: Category Nav Cards -->
  <section class="py-12 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl font-semibold text-neutral-900 mb-6">Browse by Category</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3">
        {CATEGORIES.map(cat => (
          <CategoryCard
            category={cat.id}
            count={allVendors.filter(v => v.data.category === cat.id).length}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Popular Cities -->
  {populatedCities.length > 0 && (
    <section class="py-12 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl font-semibold text-neutral-900 mb-6">Popular Cities</h2>
        <div class="flex flex-wrap gap-3">
          {populatedCities.map(city => (
            <CityCard
              city={city.slug}
              displayName={city.displayName}
              count={cityCounts[city.slug] ?? 0}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 5: Intent Entry Points -->
  <section class="py-12 bg-gradient-to-r from-primary-600 to-primary-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl font-semibold mb-2">What are you planning?</h2>
      <p class="text-primary-200 mb-8">We'll guide you to the right vendors.</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          {
            title: 'South Indian Wedding',
            description: 'Find mandapams, pandits, saree drapers, and caterers for traditional ceremonies',
            href: '/vendors?city=bangalore',
            emoji: '🪔',
          },
          {
            title: 'Budget-Friendly Picks',
            description: 'Quality vendors in the budget and mid range across all categories',
            href: '/category/venue',
            emoji: '💰',
          },
          {
            title: 'Destination Wedding',
            description: 'Venues and planners for weddings in Goa, Rajasthan, and abroad',
            href: '/category/planner',
            emoji: '✈️',
          },
        ].map(card => (
          <a
            href={card.href}
            class="block p-6 bg-white/10 hover:bg-white/20 border border-white/20 rounded-xl transition-colors group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary-700"
          >
            <div class="text-2xl mb-3">{card.emoji}</div>
            <h3 class="font-display font-semibold text-lg text-white mb-2 group-hover:text-accent-200 transition-colors">
              {card.title}
            </h3>
            <p class="text-sm text-primary-200 leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 6: Recent Listings -->
  {recentVendors.length > 0 && (
    <section class="py-12 bg-surface-alt">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-display text-2xl font-semibold text-neutral-900">Recently Added</h2>
          <a href="/vendors" class="text-sm text-primary-600 hover:underline">Browse all →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {recentVendors.map(vendor => (
            <VendorCard vendor={vendor.data} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

---
import type { Vendor } from '../content.config';
import { CATEGORY_LABELS, PRICING_LABELS } from '../lib/vendors';
import FeaturedBadge from './FeaturedBadge.astro';

interface Props {
  vendor: Vendor;
  variant?: 'default' | 'compact';
}

const { vendor, variant = 'default' } = Astro.props;

const pricingColors: Record<Vendor['pricingRange'], string> = {
  budget: 'bg-neutral-100 text-neutral-600',
  mid: 'bg-accent-50 text-accent-600',
  premium: 'bg-primary-50 text-primary-600',
  luxury: 'bg-primary-100 text-primary-700',
};
---

<article
  class:list={[
    "relative bg-white rounded-lg border transition-all duration-200 group",
    vendor.featured
      ? "border-accent-400 ring-1 ring-accent-400 shadow-card"
      : "border-neutral-200 shadow-card hover:shadow-card-hover hover:border-primary-200"
  ]}
>
  <!-- Featured badge -->
  {vendor.featured && (
    <div class="absolute top-3 left-3 z-10">
      <FeaturedBadge />
    </div>
  )}

  <div class="p-4">
    <!-- Category badge -->
    <div class="mb-2">
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-600">
        {CATEGORY_LABELS[vendor.category]}
      </span>
    </div>

    <!-- Name + verified -->
    <h3 class="font-display font-semibold text-neutral-900 text-base leading-tight mb-1">
      <!-- Stretched link — the pseudo-element covers the whole card -->
      <a
        href={`/vendors/${vendor.slug}`}
        class="after:absolute after:inset-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 rounded-lg"
      >
        {vendor.name}
      </a>
      {vendor.verified && (
        <span class="inline-flex items-center ml-1 align-middle" aria-label="Verified vendor">
          <svg class="w-4 h-4 text-blue-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
    </h3>

    <!-- City -->
    <p class="text-xs text-neutral-500 mb-2 capitalize">{vendor.city}</p>

    <!-- Description (omitted in compact variant) -->
    {variant === 'default' && (
      <p class="text-sm text-neutral-600 line-clamp-2 mb-3">{vendor.description}</p>
    )}

    <!-- Pricing badge -->
    <div class="flex items-center justify-between mt-auto pt-1">
      <span class:list={["inline-block px-2 py-0.5 rounded-full text-xs font-medium", pricingColors[vendor.pricingRange]]}>
        {PRICING_LABELS[vendor.pricingRange]}
      </span>
    </div>
  </div>
</article>

---
interface Vendor {
  slug: string;
  name: string;
  category: 'venue' | 'photographer' | 'makeup' | 'caterer' | 'decorator' | 'dj' | 'pandit' | 'planner';
  city: string;
  description: string;
  pricing_range: 'budget' | 'mid' | 'premium' | 'luxury';
  featured?: boolean;
  verified?: boolean;
}

interface Props {
  vendor: Vendor;
  variant?: 'default' | 'compact';
}

const { vendor, variant = 'default' } = Astro.props;

const categoryLabels: Record<Vendor['category'], string> = {
  venue: 'Venue',
  photographer: 'Photographer',
  makeup: 'Makeup',
  caterer: 'Caterer',
  decorator: 'Decorator',
  dj: 'DJ',
  pandit: 'Pandit',
  planner: 'Planner',
};

const pricingLabels: Record<Vendor['pricing_range'], string> = {
  budget: 'Budget',
  mid: 'Mid-range',
  premium: 'Premium',
  luxury: 'Luxury',
};

const pricingColors: Record<Vendor['pricing_range'], string> = {
  budget: 'bg-green-50 text-green-700',
  mid: 'bg-blue-50 text-blue-700',
  premium: 'bg-purple-50 text-purple-700',
  luxury: 'bg-amber-50 text-amber-700',
};
---

<article
  class:list={[
    "relative bg-white rounded-lg border transition-all duration-200 group",
    vendor.featured
      ? "border-accent-400 ring-1 ring-accent-400 shadow-card"
      : "border-neutral-200 shadow-card hover:shadow-card-hover hover:border-primary-200"
  ]}
>
  <!-- Featured badge -->
  {vendor.featured && (
    <div class="absolute top-3 left-3 z-10">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-accent-400 text-white">
        <svg class="w-3 h-3" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Featured
      </span>
    </div>
  )}

  <div class="p-4">
    <!-- Category badge -->
    <div class="mb-2">
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-600">
        {categoryLabels[vendor.category]}
      </span>
    </div>

    <!-- Name + verified -->
    <h3 class="font-display font-semibold text-neutral-900 text-base leading-tight mb-1">
      <!-- Stretched link — the pseudo-element covers the whole card -->
      <a
        href={`/vendors/${vendor.slug}`}
        class="after:absolute after:inset-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 rounded-lg"
      >
        {vendor.name}
      </a>
      {vendor.verified && (
        <span class="inline-flex items-center ml-1 align-middle" aria-label="Verified vendor">
          <svg class="w-4 h-4 text-blue-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
    </h3>

    <!-- City -->
    <p class="text-xs text-neutral-500 mb-2 capitalize">{vendor.city}</p>

    <!-- Description (omitted in compact variant) -->
    {variant === 'default' && (
      <p class="text-sm text-neutral-600 line-clamp-2 mb-3">{vendor.description}</p>
    )}

    <!-- Pricing badge -->
    <div class="flex items-center justify-between mt-auto pt-1">
      <span class:list={["inline-block px-2 py-0.5 rounded-full text-xs font-medium", pricingColors[vendor.pricing_range]]}>
        {pricingLabels[vendor.pricing_range]}
      </span>
    </div>
  </div>
</article>

---
// No props — modal is a singleton, controlled by #search-trigger in Header
---

<dialog
  id="search-dialog"
  class="w-full max-w-2xl mx-auto mt-20 p-0 rounded-xl shadow-2xl border border-neutral-200 bg-white backdrop:bg-black/40 open:flex flex-col"
  aria-label="Search vendors"
  aria-modal="true"
>
  <div class="flex items-center justify-between px-4 pt-4">
    <span class="text-sm font-medium text-neutral-500">Search vendors</span>
    <button
      id="search-close"
      class="rounded-md p-1 text-neutral-500 hover:text-neutral-900 hover:bg-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary-600"
      aria-label="Close search"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
  <div class="p-4 flex-1 overflow-y-auto">
    <div id="pagefind-modal-ui"></div>
  </div>
</dialog>

<script is:inline>
  // Pagefind UI is loaded dynamically to avoid SSR issues
  let uiInitialized = false;

  async function initPagefind() {
    if (uiInitialized) return;
    if (!document.querySelector('link[href="/_pagefind/pagefind-ui.css"]')) {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/_pagefind/pagefind-ui.css';
      document.head.appendChild(link);
    }
    // @ts-ignore — Pagefind is a static asset, not an npm package
    const { PagefindUI } = await import('/_pagefind/pagefind-ui.js');
    new PagefindUI({ element: '#pagefind-modal-ui', showImages: false });
    uiInitialized = true;
  }

  const dialog = document.getElementById('search-dialog');
  const trigger = document.getElementById('search-trigger');
  const closeBtn = document.getElementById('search-close');

  function openModal() {
    dialog?.showModal();
    trigger?.setAttribute('aria-expanded', 'true');
    initPagefind();
  }

  function closeModal() {
    dialog?.close();
    trigger?.setAttribute('aria-expanded', 'false');
    trigger?.focus();
  }

  trigger?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);

  // Close on backdrop click
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) closeModal();
  });

  // Sync aria-expanded when dialog closes via Escape key
  dialog?.addEventListener('close', () => {
    trigger?.setAttribute('aria-expanded', 'false');
    trigger?.focus();
  });

  // Keyboard shortcut: Cmd+K / Ctrl+K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (dialog?.open) {
        closeModal();
      } else {
        openModal();
      }
    }
  });
</script>

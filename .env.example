# Dakshna Support Tooling — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Classified Hunter ──────────────────────────────────────────────────────────

# Google Places API key (optional — enables Google Maps source)
GOOGLE_PLACES_API_KEY=

# Milliseconds to wait between scrape requests (default: 2000)
SCRAPE_DELAY_MS=2000

# Max retries per request before giving up (default: 3)
SCRAPE_MAX_RETRIES=3

# ── YouTube Enrichment ─────────────────────────────────────────────────────────

# YouTube Data API v3 key (required for youtube-enrichment tool)
YOUTUBE_API_KEY=

# ── Public Submission Form (Cloudflare Function) ───────────────────────────────

# GitHub Personal Access Token with repo scope — creates branches and PRs
GITHUB_TOKEN=

# GitHub repository owner (default: adirola)
GITHUB_OWNER=adirola

# GitHub repository name (default: dakshna)
GITHUB_REPO=dakshna

# ── Cloudflare Analytics (Growth Tools) ───────────────────────────────────────

# Cloudflare API token with Analytics:Read permission
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (found in the Cloudflare dashboard sidebar)
CLOUDFLARE_ACCOUNT_ID=
